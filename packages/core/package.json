{
  "name": "@vue-modality/core",
  "version": "0.1.0",
  "description": "Lightweight modal library for Vue 3 with namespace queues, guard system, and promise-based prompt pattern. Zero dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rh00x/vue-modality",
    "directory": "packages/core"
  },
  "homepage": "https://rh00x.github.io/vue-modality/",
  "bugs": "https://github.com/rh00x/vue-modality/issues",
  "keywords": [
    "vue",
    "vue3",
    "modal",
    "dialog",
    "popup",
    "toast",
    "sidebar",
    "typescript",
    "promise",
    "guard",
    "namespace",
    "lightweight"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vue": "^3.5.13"
  }
}
